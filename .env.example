# NEXT_PUBLIC_GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
NEXT_PUBLIC_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DROPBOX_CLIENT_ID: Required for Dropbox OAuth integration.
# Get this from Dropbox App Console (https://www.dropbox.com/developers/apps).
DROPBOX_CLIENT_ID=""

# DROPBOX_CLIENT_SECRET: Required for Dropbox OAuth integration.
# Get this from Dropbox App Console (https://www.dropbox.com/developers/apps).
DROPBOX_CLIENT_SECRET=""

# DROPBOX_SAVE_PATH: The folder path in Dropbox where markdown files will be saved.
# Default is /Obsidian/Journals/
DROPBOX_SAVE_PATH="/Obsidian/Journals/"

# GOOGLE_CLIENT_ID: Required for Google Drive OAuth integration.
# Get this from Google Cloud Console (https://console.cloud.google.com/apis/credentials).
GOOGLE_CLIENT_ID=""

# GOOGLE_CLIENT_SECRET: Required for Google Drive OAuth integration.
# Get this from Google Cloud Console (https://console.cloud.google.com/apis/credentials).
GOOGLE_CLIENT_SECRET=""

# GOOGLE_DRIVE_FOLDER_ID: The ID of the Google Drive folder where audio files will be saved.
# Leave empty to save in the root directory.
# You can find the folder ID in the URL when you open a folder in Google Drive (e.g., https://drive.google.com/drive/folders/YOUR_FOLDER_ID).
GOOGLE_DRIVE_FOLDER_ID=""

# ALLOWED_EMAILS: Comma-separated list of Google email addresses allowed to use the app.
# If empty, all authenticated Google accounts are allowed.
ALLOWED_EMAILS=""
